# Example for macOS when autotools/coreutils installed by Homebrew interfere with
# vendored autotools projects. Put system tools first, then Homebrew tools.
# export PATH="/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin:${PATH}"

